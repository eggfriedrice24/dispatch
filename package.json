{
  "name": "dispatch",
  "version": "0.0.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/binbandit/dispatch.git"
  },
  "main": "dist-electron/index.js",
  "scripts": {
    "postinstall": "electron-rebuild -m . -o better-sqlite3",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "dev": "vp dev",
    "build": "vp build",
    "build:app": "bun ./scripts/build-app.mjs",
    "build:app:dir": "bun ./scripts/build-app.mjs --dir",
    "build:app:dmg": "bun ./scripts/build-app.mjs --mac dmg zip",
    "preview": "vp preview",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt --write .",
    "format:check": "vp fmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "test:watch": "vp test"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "posthog-js": "^1.362.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "rehype-raw": "^7.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.12",
  "build": {
    "appId": "dev.dispatch.app",
    "productName": "Dispatch",
    "publish": [
      {
        "provider": "github",
        "owner": "binbandit",
        "repo": "dispatch"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "*.png",
          "*.icns",
          "*.ico"
        ]
      }
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "zip"
      ],
      "darkModeSupport": true
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "resources/icon-256.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "dmg": {
      "title": "Dispatch",
      "backgroundColor": "#08080a"
    }
  }
}
